<idea-plugin>
    <id>com.commitai.plugin</id>
    <name>Commit AI (OpenAI Compatible)</name>
    <vendor email="aikilan.ft@gmail.com">Commit AI</vendor>
    <resource-bundle>messages.CommitAiBundle</resource-bundle>

    <description>
        <![CDATA[
        在提交窗口中提供 AI 生成提交消息能力，可配置 OpenAI 协议上游服务。
        ]]>
    </description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.vcs</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="com.commitai.settings.CommitAiSettings"/>
        <projectService serviceImplementation="com.commitai.settings.CommitAiProjectSettings"/>
        <projectConfigurable
                id="com.commitai.settings"
                key="settings.display.name"
                instance="com.commitai.settings.CommitAiConfigurable"/>
    </extensions>

    <actions>
        <action id="CommitAi.GenerateCommitMessageAction"
                class="com.commitai.vcs.GenerateCommitMessageAction"
                text="Commit AI"
                description="Generate commit message based on selected changes"
                icon="/icons/icon.svg">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
